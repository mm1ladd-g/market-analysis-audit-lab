# Market Analysis Audit Lab — safe, non-operational defaults.
# Copy to .env, then replace placeholders. Never commit .env.

PROJECT_NAME=Market Analysis Audit Lab
ANALYST_NAME=
SOURCE_MODE=provided
PROVIDED_SOURCES_DIR=/workspace/import
YOUTUBE_CHANNEL_URL=
YOUTUBE_CHANNEL_ID=
START_DATE=2024-01-01
END_DATE=2024-01-31
MAX_AUDIT_DAYS=120

# Collection is blocked until you explicitly confirm lawful rights/permission.
# A public URL is not a content license.
SOURCE_RIGHTS_ACKNOWLEDGED=false
SUBTITLE_LANGUAGES=fa-orig,fa-IR,fa,en-orig,en
COLLECT_THUMBNAILS=false
TRANSCRIPTION_FALLBACK=false
OPENAI_TRANSCRIPTION_MODEL=whisper-1
TRANSCRIPTION_LANGUAGE=
TRANSCRIPTION_PROMPT=
TRANSCRIPTION_CHUNK_SECONDS=1200
RETAIN_RAW_AUDIO=false
REQUIRE_SUBTITLES_FOR_AUDIT=true
STRICT_SOURCE_CHANNEL=true
MAX_SCAN_ITEMS=220

# AI stages are blocked until both API mode and cost acknowledgement are set.
AUDIT_MODE=offline
OPENAI_API_KEY=
API_COST_ACKNOWLEDGED=false
OPENAI_MODEL_CLAIM_EXTRACTION=gpt-5.6-luna
OPENAI_MODEL_SCORING=gpt-5.6-terra
OPENAI_CLAIM_REASONING_EFFORT=low
OPENAI_SCORING_REASONING_EFFORT=low
OPENAI_MAX_RETRIES=2
OPENAI_CONCURRENCY=3
OPENAI_TIMEOUT_SECONDS=180

# Optional cost ledger. Enter current operator-verified USD rates; no stale prices are embedded here.
OPENAI_CLAIM_INPUT_USD_PER_1M=
OPENAI_CLAIM_CACHED_INPUT_USD_PER_1M=
OPENAI_CLAIM_OUTPUT_USD_PER_1M=
OPENAI_SCORING_INPUT_USD_PER_1M=
OPENAI_SCORING_CACHED_INPUT_USD_PER_1M=
OPENAI_SCORING_OUTPUT_USD_PER_1M=

AUDIT_SCOPE_CATEGORIES=crypto,global_markets
CATEGORY_OVERRIDES_FILE=/app/configs/categories.example.json
ASSET_MAP_FILE=/app/configs/assets.example.json
PRICE_OUTCOME_ONLY=true

# CSV is recommended for licensed/exact international feeds. yfinance is an explicit convenience proxy.
INTERNATIONAL_MARKET_PROVIDER=csv
MARKET_CSV_DIR=/workspace/market-data

# Local/private by default. In public mode, finalization and public downloads remain
# blocked until `audit_lab.cli review accept` binds a named human decision to the
# current collection, outcome, and scoring hashes. Any artifact change makes it stale.
# Enabling the claim ledger may expose transcript excerpts and scoring reasoning.
PUBLICATION_MODE=private
PUBLIC_CLAIM_LEDGER=false
REPORT_DEFAULT_LANGUAGE=en
WORKSPACE_DIR=/workspace

# Compose worker UID/GID for native Linux bind mounts. Set these to `id -u` / `id -g` when needed.
LOCAL_UID=1000
LOCAL_GID=1000
